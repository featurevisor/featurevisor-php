{
  "name": "featurevisor/featurevisor-php",
  "description": "Featurevisor SDK for PHP",
  "type": "library",
  "homepage": "https://featurevisor.com",
  "keywords": [
    "featurevisor",
    "feature-flag",
    "feature-flags",
    "feature-toggles",
    "feature-management"
  ],
  "authors": [
    {
      "name": "Fahad Heylaal",
      "homepage": "https://fahad19.com",
      "role": "lead"
    }
  ],
  "support": {
    "issues": "https://github.com/featurevisor/featurevisor-php/issues",
    "source": "https://github.com/featurevisor/featurevisor-php",
    "docs": "https://featurevisor.com/docs/sdks/php/"
  },
  "autoload": {
    "psr-4": {
      "Featurevisor\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Featurevisor\\Tests\\": "tests/"
    }
  },
  "config": {
    "platform": {
      "php": "8.0.0"
    },
    "sort-packages": true
  },
  "require": {
    "php": "^8.0",
    "ext-json": "*",
    "psr/log": "^2.0 || ^3.0"
  },
  "require-dev": {
    "open-feature/sdk": "^2.2",
    "phpunit/phpunit": "^9.6.33",
    "phpstan/phpstan": "^2.2"
  },
  "suggest": {
    "open-feature/sdk": "Required for Featurevisor\\OpenFeatureProvider (PHP 8.0+)"
  },
  "bin": [
    "featurevisor"
  ],
  "scripts": {
    "sast": "phpstan analyse --memory-limit=256M",
    "test": "phpunit tests"
  },
  "license": [
    "MIT"
  ]
}
